generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  plan      String   @default("free") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  warehouses Warehouse[]
  products   Product[]
  members    UserOrganization[]

  @@map("organizations")
}

// ─────────────────────────────────────────────
// INFRAESTRUCTURA
// ─────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid @map("org_id")
  name      String   @db.VarChar(255)
  location  String?
  createdAt DateTime @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stock         Stock[]
  movements     Movement[]
  shiftSessions ShiftSession[]
  tasks         Task[]
  taskTemplates TaskTemplate[]

  @@map("warehouses")
}

// ─────────────────────────────────────────────
// INVENTARIO
// ─────────────────────────────────────────────

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @db.Uuid @map("org_id")
  name             String   @db.VarChar(255)
  sku              String?  @db.VarChar(100)
  unit             String   @db.VarChar(50)
  reorderThreshold Int      @default(0) @map("reorder_threshold")
  createdAt        DateTime @default(now()) @map("created_at")

  organization         Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stock                Stock[]
  movements            Movement[]
  templateConsumptions TaskTemplateConsumption[]

  @@unique([orgId, sku])
  @@map("products")
}

// Snapshot del stock actual — se actualiza con cada Movement
model Stock {
  id          String   @id @default(uuid()) @db.Uuid
  warehouseId String   @db.Uuid @map("warehouse_id")
  productId   String   @db.Uuid @map("product_id")
  quantity    Decimal  @default(0) @db.Decimal(12, 2)
  lastUpdated DateTime @default(now()) @map("last_updated")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@map("stock")
}

// Fuente de verdad — nunca se elimina
model Movement {
  id          String   @id @default(uuid()) @db.Uuid
  warehouseId String   @db.Uuid @map("warehouse_id")
  productId   String   @db.Uuid @map("product_id")
  type        String   @db.VarChar(50) // 'entrada' | 'salida' | 'transferencia' | 'ajuste'
  quantity    Decimal  @db.Decimal(12, 2)
  notes       String?
  // Encargado que registra el movimiento
  performedBy String?  @db.Uuid @map("performed_by")
  // Auxiliar que recibe el insumo (solo en salidas)
  deliveredTo String?  @db.Uuid @map("delivered_to")
  createdAt   DateTime @default(now()) @map("created_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  performer User?     @relation("PerformedMovements", fields: [performedBy], references: [id])
  recipient User?     @relation("ReceivedMovements", fields: [deliveredTo], references: [id])

  @@map("movements")
}

// ─────────────────────────────────────────────
// USUARIOS Y ACCESO
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  fullName          String?   @db.VarChar(255) @map("full_name")
  passwordHash      String    @map("password_hash")
  pinHash           String?   @map("pin_hash")
  pinFailedAttempts Int       @default(0) @map("pin_failed_attempts")
  pinLockedUntil    DateTime? @map("pin_locked_until")
  createdAt         DateTime  @default(now()) @map("created_at")

  organizations      UserOrganization[]
  shiftSessions      ShiftSession[]
  performedMovements Movement[]         @relation("PerformedMovements")
  receivedMovements  Movement[]         @relation("ReceivedMovements")
  assignedTasks      Task[]

  @@map("users")
}

// Rol del usuario dentro de una organización específica
model UserOrganization {
  userId String @db.Uuid @map("user_id")
  orgId  String @db.Uuid @map("org_id")
  // 'org_admin' | 'warehouse_manager' | 'staff'
  role   String @db.VarChar(50)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@map("user_organizations")
}

// ─────────────────────────────────────────────
// TURNOS
// ─────────────────────────────────────────────

model ShiftSession {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid @map("user_id")
  warehouseId String    @db.Uuid @map("warehouse_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  // Fingerprint del dispositivo para auditoría
  deviceId    String?   @map("device_id")

  user      User      @relation(fields: [userId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("shift_sessions")
}

// ─────────────────────────────────────────────
// TAREAS Y PRODUCTIVIDAD
// ─────────────────────────────────────────────

// Template para tareas recurrentes (cron-driven)
model TaskTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  warehouseId String   @db.Uuid @map("warehouse_id")
  title       String   @db.VarChar(255)
  description String?
  // Expresión cron estándar. Ej: "0 9 * * 1-5" = lunes a viernes a las 09:00
  cronExpr    String   @db.VarChar(100) @map("cron_expr")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  warehouse    Warehouse                  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  tasks        Task[]
  consumptions TaskTemplateConsumption[]

  @@map("task_templates")
}

// Consumo teórico de insumos por ejecución de un template (Modelo A manual)
model TaskTemplateConsumption {
  id         String  @id @default(uuid()) @db.Uuid
  templateId String  @db.Uuid @map("template_id")
  productId  String  @db.Uuid @map("product_id")
  // Cantidad por CADA ejecución del template (ej: 0.2 para 200ml)
  quantity   Decimal @db.Decimal(12, 3)

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])

  @@unique([templateId, productId])
  @@map("task_template_consumptions")
}

model Task {
  id          String    @id @default(uuid()) @db.Uuid
  warehouseId String    @db.Uuid @map("warehouse_id")
  // NULL si fue asignada directamente por el admin
  templateId  String?   @db.Uuid @map("template_id")
  // NULL hasta que alguien la tome de la cola
  assignedTo  String?   @db.Uuid @map("assigned_to")
  title       String    @db.VarChar(255)
  description String?
  // 'disponible' | 'en_progreso' | 'completada'
  // 'disponible' | 'en_progreso' | 'completada_pendiente_foto' | 'completada'
  status             String    @default("disponible") @db.VarChar(50)
  scheduledFor       DateTime? @map("scheduled_for")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  // Límite para subir la foto pendiente — 2h desde completedAt
  photoDeadline      DateTime? @map("photo_deadline")
  afterPhotoRequired Boolean   @default(true) @map("after_photo_required")
  createdAt          DateTime  @default(now()) @map("created_at")

  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  template  TaskTemplate? @relation(fields: [templateId], references: [id])
  user      User?         @relation(fields: [assignedTo], references: [id])
  photos    TaskPhoto[]

  @@map("tasks")
}

// Evidencia fotográfica — almacenada en Supabase Storage
model TaskPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @db.Uuid @map("task_id")
  // URL pública de Supabase Storage
  url       String
  // 'antes' | 'despues'
  type      String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, type])
  @@map("task_photos")
}
