# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtenlos en: https://supabase.com/dashboard → tu proyecto → Settings → Database

# Pooler (puerto 6543) — para queries en runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (puerto 5432) — solo para migraciones con Prisma
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio"
JWT_EXPIRES_IN="7d"

# Duración de la sesión de turno en horas (default: 12)
SHIFT_SESSION_HOURS=12

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase Storage (para fotos de tareas) ──────────────────────────────────
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key_aqui"
SUPABASE_STORAGE_BUCKET="task-photos"
