# ═══════════════════════════════════════════════════════════════
# Variables de entorno para Railway
# Dashboard Railway → tu proyecto → Variables → "Raw Editor"
# Pega estas variables con sus valores reales (sin comillas)
# ═══════════════════════════════════════════════════════════════

# ── Supabase PostgreSQL ──────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# Usa el "Transaction pooler" (puerto 6543) — Railway usa conexiones cortas
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# URL directa sin pooler (puerto 5432) — Prisma la usa para migrate deploy
DIRECT_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase Storage (fotos de tareas) ───────────────────────────
# Supabase → Project Settings → API
SUPABASE_URL=https://XXXX.supabase.co

# ⚠️  DEBE ser la service_role key — NO la anon/public key
# La anon key no tiene permisos para crear signed upload URLs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nombre del bucket en Supabase Storage (default: task-photos)
# Cámbialo solo si creaste el bucket con otro nombre
SUPABASE_STORAGE_BUCKET=task-photos

# ── JWT ──────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 64 caracteres. NUNCA reutilizar entre proyectos.
JWT_SECRET=GENERA_UN_SECRETO_LARGO_AQUI
JWT_EXPIRES_IN=7d

# ── Turnos ───────────────────────────────────────────────────────
SHIFT_SESSION_HOURS=12

# ── CORS ─────────────────────────────────────────────────────────
# Tu URL de Railway una vez que el primer deploy esté listo.
# Formato: https://tu-app.up.railway.app
# Si tienes dominio personalizado agrégalo separado por coma:
# ALLOWED_ORIGINS=https://tu-app.up.railway.app,https://bodega.tudominio.com
ALLOWED_ORIGINS=https://tu-app.up.railway.app

# ── Node ─────────────────────────────────────────────────────────
NODE_ENV=production
# PORT lo inyecta Railway automáticamente — NO la definas aquí

# ═══════════════════════════════════════════════════════════════
# CHECKLIST PRE-DEPLOY
# ═══════════════════════════════════════════════════════════════
# [ ] DATABASE_URL apunta al Transaction pooler (puerto 6543)
# [ ] DIRECT_URL apunta al puerto 5432 (sin pgbouncer)
# [ ] SUPABASE_SERVICE_ROLE_KEY es el service_role, no el anon key
# [ ] JWT_SECRET es único y tiene >= 64 caracteres
# [ ] ALLOWED_ORIGINS tiene la URL exacta que Railway asignó
# [ ] El bucket "task-photos" en Supabase tiene RLS configurado
#     para service_role (o RLS desactivado en ese bucket)
# [ ] pg_cron configurado en Supabase (supabase/cron.sql)
# ═══════════════════════════════════════════════════════════════

# ── Railway Build & Start Commands ──────────────────────────────
# En Railway → Settings → Deploy:
#   Build Command:  npm run build       (ejecuta: prisma generate)
#   Start Command:  npm start           (ejecuta: prisma migrate deploy && node src/index.js)
